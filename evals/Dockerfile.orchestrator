FROM roo-code-evals-base:latest

USER root

# Install Docker Compose
RUN curl -L "https://github.com/docker/compose/releases/download/v2.24.6/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose \
    && chmod +x /usr/local/bin/docker-compose

# Set working directory
WORKDIR /app

# Copy package files
COPY --chown=coder:coder package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./

# Copy the CLI app and necessary packages
COPY --chown=coder:coder apps/cli ./apps/cli/
COPY --chown=coder:coder packages ./packages/
COPY --chown=coder:coder config ./config/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Create TypeScript files that are referenced in the imports
RUN mkdir -p packages/types/dist
RUN touch packages/types/dist/exercises.js packages/types/dist/ipc.js packages/types/dist/roo-code.js packages/types/dist/roo-code-defaults.js
RUN mkdir -p packages/db/dist
RUN touch packages/db/dist/schema.js

# Build the TypeScript packages first
RUN pnpm --filter @evals/types tsc || true
RUN pnpm --filter @evals/db tsc || true
RUN pnpm --filter @evals/ipc tsc || true

# Copy the TypeScript files to their JavaScript locations if they don't exist
RUN for file in packages/types/src/*.ts; do \
      jsfile="$(echo "$file" | sed 's/src/dist/;s/\.ts$/.js/')"; \
      if [ ! -f "$jsfile" ]; then \
        mkdir -p "$(dirname "$jsfile")"; \
        cp "$file" "$jsfile"; \
        sed -i 's/\.ts"/.js"/g' "$jsfile"; \
      fi \
    done

# Create directory for exercises
RUN mkdir -p /app/exercises

# Copy the modified CLI code (will be created later)
COPY --chown=coder:coder docker/orchestrator.js ./apps/cli/src/

# Switch to non-root user
USER coder

# Ensure Rust is in the PATH for the coder user
ENV PATH="/home/coder/.cargo/bin:${PATH}"

# Environment variables
ENV BENCHMARKS_DB_PATH="/app/data/evals.db"
ENV OPENROUTER_API_KEY=""

# Expose the orchestrator API port
EXPOSE 4000

# Start the orchestrator
CMD ["pnpm", "cli"]